# Required
GEMINI_API_KEY=your_gemini_api_key_here
ENCRYPTION_SECRET_KEY=your_32_char_aes_key_here

# PostgreSQL (defaults work with docker-compose)
DB_HOST=localhost
DB_USER=codeturret
DB_PASSWORD=codeturret

# RabbitMQ (defaults work with docker-compose)
RABBITMQ_HOST=localhost
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Snowflake (for Cortex AI chat — optional, Ask feature won't work without it)
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_snowflake_user
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_WAREHOUSE=CODEBOUNCER_WH
SNOWFLAKE_DATABASE=CODEBOUNCER
SNOWFLAKE_SCHEMA=CORE
